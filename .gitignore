# --- Secrets ---
# Your MTA Bus Time API key lives here. Never commit it.
.env
.env.*
!.env.example

# --- Python ---
__pycache__/
*.py[cod]
*.egg-info/
.venv/
venv/
env/
.pytest_cache/
.mypy_cache/
.ruff_cache/

# --- Downloaded transit data ---
data/gtfs_static/
*.zip
data/cache/
*.pb
# ...but committed test fixtures (a captured real feed) are not "downloaded data".
!backend/tests/fixtures/*.pb

# --- Node (dev-only: the Playwright e2e suite under tests/e2e; the app is buildless) ---
node_modules/
dist/
npm-debug.log*

# --- Playwright e2e artifacts (generated by a test run, not source) ---
test-results/
playwright-report/
blob-report/
.playwright/

# --- OS / editor junk ---
.DS_Store
Thumbs.db
.idea/
.vscode/
*.swp
